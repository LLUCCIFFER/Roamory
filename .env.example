# Copy this file to .env.local for local development.
# Never commit real provider keys.

# Gaode / Amap Web Service API, used by route and POI adapters.
AMAP_WEB_SERVICE_KEY=
GAODE_WEB_SERVICE_KEY=

# Gaode / Amap JavaScript API, used only by the browser map renderer.
# For production, prefer a domain/proxy-based security setup instead of exposing sensitive server keys.
NEXT_PUBLIC_AMAP_JSAPI_KEY=
NEXT_PUBLIC_AMAP_SECURITY_JS_CODE=

# Future provider adapters.
OPEN_METEO_BASE_URL=https://api.open-meteo.com
OPENROUTESERVICE_API_KEY=

# AI generation provider. Use mock by default; switch to gemini or ollama locally.
LLM_PROVIDER=mock
LLM_ALLOW_MOCK_FALLBACK=true
LLM_REQUEST_TIMEOUT_MS=30000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
